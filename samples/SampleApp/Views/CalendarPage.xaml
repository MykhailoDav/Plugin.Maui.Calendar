<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SampleApp.Views.CalendarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SampleApp.ViewModels"
    xmlns:mtk="clr-namespace:MemoryToolkit.Maui;assembly=MemoryToolkit.Maui"
    xmlns:plugin="clr-namespace:Plugin.Maui.Calendar.Controls;assembly=Plugin.Maui.Calendar"
    Title="CalendarPage"
    mtk:LeakMonitorBehavior.Cascade="True"
    x:DataType="local:CalendarViewModel"
    Shell.TabBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout>
            <Picker
                Title="Оберіть мову"
                HorizontalOptions="Center"
                ItemsSource="{Binding Languages}"
                SelectedItem="{Binding SelectedLanguage}" />
            <plugin:Calendar Culture="{Binding CalendarCulture}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
